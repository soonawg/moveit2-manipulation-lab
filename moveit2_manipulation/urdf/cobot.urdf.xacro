<?xml version="1.0"?>
<robot name="cobot" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:include filename="$(find my_manipulation_robot)/urdf//joint_link.xacro"/>

    <!-- Fix the cobot to the world -->
    <link name="world"/>
    
    <joint name="fixed" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
    </joint>

    
    <xacro:cobot_link_cylinder name="base_link" origin_xyz="0.0 0.0 0.025" origin_rpy="0 0 0" radius="0.1" length="0.05"
                                mass="1" ixx="0.01625" ixy="0" ixz="0" iyy="0.01625" iyz="0" izz="0.005"/>


    <xacro:cobot_link_cylinder name="link1" origin_xyz="0.0 0.0 0.132" origin_rpy="0 0 0" radius="0.05" length="0.264"
                                mass="1.5" ixx="0.054147" ixy="0" ixz="0" iyy="0.054147" iyz="0" izz="0.001875"/>


    <xacro:cobot_joint name="base_link__link1" type="revolute" parent="base_link" child="link1"
                            axis="0 0 1" limit_l="-3.14159" limit_u="3.14159" limit_e="1000" limit_v="0.5" origin_xyz="0 0 0.05" origin_rpy="0.0 0.0 0.0"/>


    <xacro:cobot_link_cylinder name="link2" origin_xyz="0.0 0.0 0.425" origin_rpy="0 0 0" radius="0.05" length="0.850"
                                mass="2" ixx="0.4816" ixy="0" ixz="0" iyy="0" iyz="0" izz="0.4816"/>


    <xacro:cobot_joint name="link1__link2" type="revolute" parent="link1" child="link2"
                            axis="0.0 1 0.0" limit_l="-3.14159" limit_u="3.14159" limit_e="1000" limit_v="0.5" origin_xyz="0 0.1 0.214" origin_rpy="0.0 0.0 0.0"/>


    <xacro:cobot_link_cylinder name="link3" origin_xyz="0.0 0.0 0.340" origin_rpy="0 0 0" radius="0.05" length="0.680"
                                mass="2" ixx="0.4816" ixy="0" ixz="0" iyy="0" iyz="0" izz="0.4816"/>

    <xacro:cobot_joint name="link2__link3" type="revolute" parent="link2" child="link3"
                            axis="0.0 1 0.0" limit_l="-3.14" limit_u="3.14" limit_e="1000" limit_v="0.5" origin_xyz="0 -0.1 0.8" origin_rpy="0.0 0.0 0.0"/>

    
    <xacro:cobot_link_cylinder name="link4" origin_xyz="0.0 0.0 0.065" origin_rpy="0 0 0" radius="0.05" length="0.130"
                                mass="1" ixx="0.00565" ixy="0" ixz="0" iyy="0" iyz="0" izz="0.00565"/>

    <xacro:cobot_joint name="link3__link4" type="revolute" parent="link3" child="link4"
                            axis="0.0 1 0.0" limit_l="-3.14" limit_u="3.14" limit_e="1000" limit_v="0.5" origin_xyz="0 0.1 0.630" origin_rpy="0.0 0.0 0.0"/>


    
    <xacro:cobot_link_cylinder name="link5" origin_xyz="0.0 0.0 0.035" origin_rpy="0 0 0" radius="0.05" length="0.170"
                                mass="2" ixx="0.4816" ixy="0" ixz="0" iyy="0" iyz="0" izz="0.4816"/>

    <xacro:cobot_joint name="link4__link5" type="revolute" parent="link4" child="link5"
                            axis="1 0.0 0.0" limit_l="-3.14" limit_u="3.14" limit_e="1000" limit_v="0.5" origin_xyz="0 0 0.180" origin_rpy="0.0 1.57 0.0"/>
   


    <!-- TCP CONNECTOR-->

    
    <xacro:cobot_link_box name="tcp_connector" origin_xyz="0.0 0.0 0.0125" origin_rpy="0 0 0" size="0.03 0.150 0.03"
                                mass="1" ixx="0.00195" ixy="0" ixz="0" iyy="0.00195" iyz="0" izz="0.00015"/>

    <xacro:cobot_joint name="link5__tcp_connector" type="revolute" parent="link5" child="tcp_connector"
                            axis="0 0 1" limit_l="-3.14" limit_u="3.14" limit_e="1000" limit_v="0.5" origin_xyz="0 0 0.120" origin_rpy="0.0 0.0 0.0"/>

    
    <xacro:cobot_link_box name="gripper_right" origin_xyz="0.0 0.0 0.05" origin_rpy="0 0 0" size="0.01 0.01 0.1"
                        mass="0.5" ixx="0.00042" ixy="0" ixz="0" iyy="0.00042" iyz="0" izz="0.0000083"/>

    <xacro:cobot_joint name="tcp_connector__gripper_right" type="prismatic" parent="tcp_connector" child="gripper_right"
                            axis="0 1 0" limit_l="0" limit_u="0.055" limit_e="1000" limit_v="0.5" origin_xyz="0 -0.065 0.03" origin_rpy="0.0 0.0 0.0"/>

    <xacro:cobot_link_box name="gripper_left" origin_xyz="0.0 0.0 0.05" origin_rpy="0 0 0" size="0.01 0.01 0.1"
                            mass="0.5" ixx="0.00042" ixy="0" ixz="0" iyy="0.00042" iyz="0" izz="0.0000083"/>

    <!-- <xacro:cobot_joint name="tcp_connector__gripper_left" type="prismatic" parent="tcp_connector" child="gripper_left"
                            axis="0 1 0" limit_l="0" limit_u="-0.055" limit_e="1000" limit_v="0.5" origin_xyz="0 0.065 0.03" origin_rpy="0.0 0.0 0.0"/> -->

    <joint name="tcp_connector__gripper_left" type="prismatic">
      <parent link="tcp_connector"/>
      <child link="gripper_left"/>
      <axis xyz="0 1 0"/>
      <origin xyz="0 0.065 0.03" rpy="0.0 0.0 0.0"/>
      <limit lower="-0.055" upper="0" effort="1000" velocity="0.5"/>
    </joint>

    <!-- ROS2 CONTROL -->
    <ros2_control name="GazeboSystem" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
            <!-- <plugin>gazebo_ros2_control::GazeboSystem</plugin> -->
        </hardware>

        <joint name="base_link__link1">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="link1__link2">
            <command_interface name="position">
                <param name="min">-2.5</param>
                <param name="max">2.5</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        
        <joint name="link2__link3">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        

        <joint name="link3__link4">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        
        
        <joint name="link4__link5">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>
        
        <joint name="link5__tcp_connector">
            <command_interface name="position">
                <param name="min">-3.14</param>
                <param name="max">3.14</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <!-- 08/31 마지막으로 수정한 부분 -->
        <joint name="tcp_connector__gripper_right">
            <command_interface name="position">
                <param name="min">0.0</param>
                <param name="max">0.055</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

        <joint name="tcp_connector__gripper_left">
            <command_interface name="position">
                <param name="min">-0.055</param>
                <param name="max">0.0</param>
            </command_interface>
            <state_interface name="position"/>
            <state_interface name="velocity"/>
        </joint>

    </ros2_control>

    <!-- Gazebo ros2_control 플러그인 설정 추가 -->
    <gazebo>
        <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
            <robot_sim_type>gazebo_ros2_control/GazeboSystem</robot_sim_type>
            <!-- <robot_sim_type>gazebo_ros2_control::GazeboSystem</robot_sim_type> -->
            <parameters>$(find my_manipulation_robot)/config/joints_controllers.yaml</parameters>
        </plugin>
    </gazebo>
        
    <gazebo reference="gripper_right">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>2.5</mu>
                        <mu2>2.5</mu2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>3e5</kp>
                        <kd>20</kd>
                        <max_vel>0.1</max_vel>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>

    <gazebo reference="gripper_left">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <mu>2.5</mu>
                        <mu2>2.5</mu2>
                    </ode>
                </friction>
                <contact>
                    <ode>
                        <kp>3e5</kp>
                        <kd>20</kd>
                        <max_vel>0.1</max_vel>
                        <min_depth>0.001</min_depth>
                    </ode>
                </contact>
            </surface>
        </collision>
    </gazebo>

</robot>